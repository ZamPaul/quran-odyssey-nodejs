generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// ENUMS — MODULE 1
// ─────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum CourseInterest {
  NOORANI_QAIDA
  QURAN_RECITATION
  TAJWEED
  HIFZ
  ISLAMIC_STUDIES
  ONE_TO_ONE
}

enum CourseType {
  NOORANI_QAIDA
  QURAN_RECITATION
  TAJWEED
  HIFZ
  ISLAMIC_STUDIES
  ONE_TO_ONE
}

enum LeadStatus {
  NEW
  CONTACTED
  BOOKED
  CONVERTED
  LOST
}

// ─────────────────────────────────────────────────────────
// ENUMS — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  MISSED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  GRADED
  OVERDUE
}

enum ReportStatus {
  DRAFT
  SENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum EnrollmentRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  AWAITING_PAYMENT
  ACTIVE
  REJECTED
  CANCELLED
}

// ─────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Module 1 relations
  studentProfile StudentProfile?
  trialBookings  TrialBooking[]

  // Module 2 relations (NEW)
  classSessions         ClassSession[]         @relation("StudentSessions")
  enrollments           Enrollment[]           @relation("StudentEnrollments")
  assignments           Assignment[]           @relation("StudentAssignments")
  progressReports       ProgressReport[]       @relation("StudentReports")
  attendanceRecords     AttendanceRecord[]     @relation("StudentAttendance")
  teacher               Teacher?               @relation("TeacherUser")
  assignmentSubmissions AssignmentSubmission[]

  enrollmentRequests EnrollmentRequest[]
  parentProfile      ParentProfile?
  parentLinks        ParentChildLink[]   @relation("ParentLinks")
  childLinks         ParentChildLink[]   @relation("ChildLinks")

  @@map("users")
}

// ─────────────────────────────────────────────────────────
// STUDENT PROFILE
// ─────────────────────────────────────────────────────────

model StudentProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentName     String
  phone          String?
  childName      String
  childAge       Int
  country        String
  timezone       String
  courseInterest CourseInterest
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("student_profiles")
}

// ─────────────────────────────────────────────────────────
// TEACHER
// ─────────────────────────────────────────────────────────

model Teacher {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  specialty  String[]
  timezone   String
  gender     String
  bio        String?
  rating     Float    @default(0.0)
  isActive   Boolean  @default(true)
  calendarId String   @unique

  // Module 2 — link to Clerk User (NEW)
  // Admin sets this after creating the teacher's Clerk account
  userId String? @unique
  user   User?   @relation("TeacherUser", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Module 1 relations
  trialBookings TrialBooking[]

  // Module 2 relations (NEW)
  classSessions     ClassSession[]     @relation("TeacherSessions")
  enrollments       Enrollment[]       @relation("TeacherEnrollments")
  assignments       Assignment[]       @relation("TeacherAssignments")
  progressReports   ProgressReport[]   @relation("TeacherReports")
  attendanceRecords AttendanceRecord[] @relation("TeacherAttendanceRecords")

  @@map("teachers")
}

// ─────────────────────────────────────────────────────────
// TRIAL BOOKING — MODULE 1 (updated with back-relation)
// ─────────────────────────────────────────────────────────

model TrialBooking {
  id               String         @id @default(cuid())
  studentId        String
  teacherId        String? // was required — now nullable
  slotStart        DateTime
  durationMins     Int            @default(30)
  courseInterest   CourseInterest
  genderPreference String? // NEW: MALE | FEMALE | NO_PREFERENCE
  status           BookingStatus  @default(PENDING)
  calEventId       String?
  zoomLink         String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  student User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  classSession ClassSession?

  // Removed @@unique([teacherId, slotStart]) — teacher is no longer selected at booking
  // Slot conflict prevention is handled at application level (see booking route)
  @@index([slotStart])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────
// TRIAL LEAD — MODULE 1 EXTRA
// ─────────────────────────────────────────────────────────

model TrialLead {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String
  isInterested Boolean    @default(true)
  source       String     @default("landing_page")
  status       LeadStatus @default(NEW)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("trial_leads")
}

// ─────────────────────────────────────────────────────────
// CLASS SESSION — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model ClassSession {
  id String @id @default(cuid())

  teacherId String
  teacher   Teacher @relation("TeacherSessions", fields: [teacherId], references: [id])

  studentId String
  student   User   @relation("StudentSessions", fields: [studentId], references: [id])

  // Optional links — a session can belong to an enrollment or be a standalone trial
  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id])

  // If this session originated from a trial booking
  trialBookingId String?       @unique
  trialBooking   TrialBooking? @relation(fields: [trialBookingId], references: [id])

  courseType   CourseInterest
  scheduledAt  DateTime
  durationMins Int            @default(30)
  zoomLink     String?
  status       SessionStatus  @default(SCHEDULED)
  teacherNotes String?
  calEventId   String?

  // Back-relation
  attendance AttendanceRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("class_sessions")
}

// ─────────────────────────────────────────────────────────
// ENROLLMENT — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model Enrollment {
  id String @id @default(cuid())

  studentId String
  student   User   @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation("TeacherEnrollments", fields: [teacherId], references: [id])

  courseType      CourseInterest
  startDate       DateTime         @default(now())
  status          EnrollmentStatus @default(ACTIVE)
  sessionsPerWeek Int              @default(2)
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relations
  sessions          ClassSession[]
  assignments       Assignment[]
  progressReports   ProgressReport[]
  attendanceRecords AttendanceRecord[]

  @@map("enrollments")
}

// ─────────────────────────────────────────────────────────
// ASSIGNMENT — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model Assignment {
  id           String           @id @default(cuid())
  teacherId    String
  studentId    String
  enrollmentId String?
  title        String
  description  String?
  dueDate      DateTime
  status       AssignmentStatus @default(PENDING)
  courseType   CourseType
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  teacher    Teacher               @relation("TeacherAssignments", fields: [teacherId], references: [id])
  student    User                  @relation("StudentAssignments", fields: [studentId], references: [id])
  enrollment Enrollment?           @relation(fields: [enrollmentId], references: [id])
  submission AssignmentSubmission?

  @@index([teacherId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────
// ASSIGNMENT SUBMISSION — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model AssignmentSubmission {
  id           String    @id @default(cuid())
  assignmentId String    @unique
  studentId    String
  content      String?
  fileUrl      String?
  grade        String?
  feedback     String?
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id])
}

// ─────────────────────────────────────────────────────────
// PROGRESS REPORT — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model ProgressReport {
  id           String       @id @default(cuid())
  teacherId    String
  studentId    String
  enrollmentId String?
  period       String // e.g. "Week 12", "Month 3", "June 2026"
  courseType   CourseType
  status       ReportStatus @default(DRAFT)

  // Structured report fields
  overallRating   Int? // 1–5
  tajweedProgress String?
  recitationNotes String?
  behaviourNotes  String?
  homeworkNotes   String?
  teacherMessage  String? // personal message to parent
  nextSteps       String?

  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  teacher    Teacher     @relation("TeacherReports", fields: [teacherId], references: [id])
  student    User        @relation("StudentReports", fields: [studentId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])

  @@index([teacherId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────
// ATTENDANCE RECORD — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model AttendanceRecord {
  id           String           @id @default(cuid())
  teacherId    String
  studentId    String
  sessionId    String           @unique // one record per session
  enrollmentId String?
  status       AttendanceStatus
  notes        String?
  markedAt     DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  teacher    Teacher      @relation("TeacherAttendanceRecords", fields: [teacherId], references: [id])
  student    User         @relation("StudentAttendance", fields: [studentId], references: [id])
  session    ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment Enrollment?  @relation(fields: [enrollmentId], references: [id])

  @@index([teacherId])
  @@index([studentId])
  @@index([sessionId])
}

// ─────────────────────────────────────────────────────────
// ENROLLMENT REQUEST — MODULE 3
// ─────────────────────────────────────────────────────────
model EnrollmentRequest {
  id               String                  @id @default(cuid())
  studentId        String
  courseType       CourseInterest
  genderPreference String?
  preferredDays    String[]
  preferredTime    String?
  message          String?
  status           EnrollmentRequestStatus @default(PENDING)
  adminNotes       String?
  rejectionReason  String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("enrollment_requests")
}

// ─────────────────────────────────────────────────────────
// PARENT PROFILE — MODULE 3
// ─────────────────────────────────────────────────────────
model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("parent_profiles")
}

// ─────────────────────────────────────────────────────────
// PARENT CHILD LINK — MODULE 3
// ─────────────────────────────────────────────────────────
model ParentChildLink {
  id           String   @id @default(cuid())
  parentUserId String
  childUserId  String
  relationship String   @default("PARENT")
  isPrimary    Boolean  @default(true)
  createdAt    DateTime @default(now())

  parent User @relation("ParentLinks", fields: [parentUserId], references: [id], onDelete: Cascade)
  child  User @relation("ChildLinks",  fields: [childUserId],  references: [id], onDelete: Cascade)

  @@unique([parentUserId, childUserId])
  @@index([parentUserId])
  @@index([childUserId])
  @@map("parent_child_links")
}