generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// ENUMS — MODULE 1
// ─────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum CourseInterest {
  NOORANI_QAIDA
  QURAN_RECITATION
  TAJWEED
  HIFZ
  ISLAMIC_STUDIES
  ONE_TO_ONE
}

enum CourseType {
  NOORANI_QAIDA
  QURAN_RECITATION
  TAJWEED
  HIFZ
  ISLAMIC_STUDIES
  ONE_TO_ONE
}

enum LeadStatus {
  NEW
  CONTACTED
  BOOKED
  CONVERTED
  LOST
}

// ─────────────────────────────────────────────────────────
// ENUMS — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  MISSED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  GRADED
  OVERDUE
}

enum ReportStatus {
  DRAFT
  SENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum EnrollmentRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  AWAITING_PAYMENT
  ACTIVE
  REJECTED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CommChannel { 
  EMAIL
  WHATSAPP 
}

enum CommStatus { 
  SENT 
  FAILED 
}

enum CommType {
  LEAD_CONFIRMATION
  ADMIN_LEAD_NOTIFICATION
  TRIAL_BOOKING_CONFIRMATION
  ADMIN_TRIAL_NOTIFICATION
  ENROLLMENT_ADMIN_NOTIFICATION
  ENROLLMENT_APPROVED
  ENROLLMENT_REJECTED
  PROGRESS_REPORT
  TEACHER_DUTIES_REMINDER
  OTHER
}

// ─────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  role      Role     @default(STUDENT)

  // NEW — account-holder contact info (locked decision #1)
  name      String?
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    UserStatus @default(ACTIVE)   // ← NEW (soft-suspend)

  // NEW — the learners this account owns/manages
  managedStudents Student[] @relation("AccountStudents")

  // KEPT — existing relations, unchanged. These still point at User
  // because the DB foreign keys still reference `users`. They are
  // removed at the end of Phase 2 when the 8 FKs are flipped to Student.
  teacher   Teacher? @relation("TeacherUser")
  auditLogs AuditLog[] @relation("AuditActor")

  convertedLeads  TrialLead[] @relation("LeadConversions")

  @@map("users")
}

model AuditLog {
  id          String   @id @default(cuid())

  // Who did it (nullable so history survives admin deletion)
  actorId     String?
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail  String?  // denormalised snapshot

  // What happened
  action      String   // e.g. "account.suspend", "student.delete"
  targetType  String?  // e.g. "User", "Student", "Enrollment"
  targetId    String?
  targetLabel String?  // human snapshot e.g. student name/email

  metadata    Json?    // before/after or extra context
  ip          String?

  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
}

model Student {
  id        String @id @default(cuid())

  // The account holder who owns/manages this learner
  accountId String
  account   User   @relation("AccountStudents", fields: [accountId], references: [id], onDelete: Cascade)

  // Learner details (will be backfilled from StudentProfile in Phase 2)
  name           String
  age            Int
  dateOfBirth    DateTime?   
  country        String
  timezone       String
  gender         String?         // for teacher matching; optional
  courseInterest CourseInterest

  // true when the account holder IS the learner (solo adult)
  isSelf    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NOTE: No trialBookings / enrollments / classSessions / assignments /
  // assignmentSubmissions / progressReports / attendanceRecords /
  // enrollmentRequests here YET. They are added in Phase 2's FK-flip
  // migration, together with repointing the other side of each relation.
  trialBookings         TrialBooking[]
  enrollmentRequests    EnrollmentRequest[]
  enrollments           Enrollment[]           @relation("StudentEnrollments")
  classSessions         ClassSession[]         @relation("StudentSessions")
  assignments           Assignment[]           @relation("StudentAssignments")
  assignmentSubmissions AssignmentSubmission[]
  progressReports       ProgressReport[]       @relation("StudentReports")
  attendanceRecords     AttendanceRecord[]     @relation("StudentAttendance")

  @@index([accountId])
  @@map("students")
}

// ─────────────────────────────────────────────────────────
// TEACHER
// ─────────────────────────────────────────────────────────

model Teacher {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  specialty  String[]
  timezone   String
  gender     String
  bio        String?
  rating     Float    @default(0.0)
  isActive   Boolean  @default(true)
  calendarId String   @unique

  // Module 2 — link to Clerk User (NEW)
  // Admin sets this after creating the teacher's Clerk account
  userId String? @unique
  user   User?   @relation("TeacherUser", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Module 1 relations
  trialBookings TrialBooking[]

  // Module 2 relations (NEW)
  classSessions     ClassSession[]     @relation("TeacherSessions")
  enrollments       Enrollment[]       @relation("TeacherEnrollments")
  assignments       Assignment[]       @relation("TeacherAssignments")
  progressReports   ProgressReport[]   @relation("TeacherReports")
  attendanceRecords AttendanceRecord[] @relation("TeacherAttendanceRecords")

  @@map("teachers")
}

// ─────────────────────────────────────────────────────────
// TRIAL BOOKING — MODULE 1 (updated with back-relation)
// ─────────────────────────────────────────────────────────

model TrialBooking {
  id               String         @id @default(cuid())
  studentId        String
  teacherId        String? // was required — now nullable
  slotStart        DateTime
  durationMins     Int            @default(30)
  courseInterest   CourseInterest
  genderPreference String? // NEW: MALE | FEMALE | NO_PREFERENCE
  status           BookingStatus  @default(PENDING)
  calEventId       String?
  zoomLink         String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  classSession ClassSession?

  // Removed @@unique([teacherId, slotStart]) — teacher is no longer selected at booking
  // Slot conflict prevention is handled at application level (see booking route)
  @@index([slotStart])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────
// TRIAL LEAD — MODULE 1 EXTRA
// ─────────────────────────────────────────────────────────

model TrialLead {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String
  isInterested Boolean    @default(true)
  source       String     @default("landing_page")
  status       LeadStatus @default(NEW)
  notes        String?

  convertedUserId String?
  convertedUser   User?   @relation("LeadConversions", fields: [convertedUserId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("trial_leads")
}

// ─────────────────────────────────────────────────────────
// CLASS SESSION — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model ClassSession {
  id String @id @default(cuid())

  teacherId String
  teacher   Teacher @relation("TeacherSessions", fields: [teacherId], references: [id])

  studentId String
  student   Student   @relation("StudentSessions", fields: [studentId], references: [id])

  // Optional links — a session can belong to an enrollment or be a standalone trial
  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id])

  // If this session originated from a trial booking
  trialBookingId String?       @unique
  trialBooking   TrialBooking? @relation(fields: [trialBookingId], references: [id])

  courseType   CourseInterest
  scheduledAt  DateTime
  durationMins Int            @default(30)
  zoomLink     String?
  status       SessionStatus  @default(SCHEDULED)
  teacherNotes String?
  calEventId   String?

  // Back-relation
  attendance AttendanceRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("class_sessions")
}

// ─────────────────────────────────────────────────────────
// ENROLLMENT — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model Enrollment {
  id String @id @default(cuid())

  studentId String
  student   Student @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation("TeacherEnrollments", fields: [teacherId], references: [id])

  courseType      CourseInterest
  startDate       DateTime         @default(now())
  status          EnrollmentStatus @default(ACTIVE)
  sessionsPerWeek Int              @default(2)
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relations
  sessions          ClassSession[]
  assignments       Assignment[]
  progressReports   ProgressReport[]
  attendanceRecords AttendanceRecord[]

  @@map("enrollments")
}

// ─────────────────────────────────────────────────────────
// ASSIGNMENT — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model Assignment {
  id           String           @id @default(cuid())
  teacherId    String
  studentId    String
  enrollmentId String?
  title        String
  description  String?

  // ── File attachment (teacher uploads when creating assignment) ──
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  attachmentPath String?   // ← ADD THIS (Supabase Storage path, for deletion)

  dueDate      DateTime
  status       AssignmentStatus @default(PENDING)
  courseType   CourseType
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  teacher    Teacher               @relation("TeacherAssignments", fields: [teacherId], references: [id])
  student    Student                  @relation("StudentAssignments", fields: [studentId], references: [id])
  enrollment Enrollment?           @relation(fields: [enrollmentId], references: [id])
  submission AssignmentSubmission?

  @@index([teacherId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────
// ASSIGNMENT SUBMISSION — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model AssignmentSubmission {
  id           String    @id @default(cuid())
  assignmentId String    @unique
  studentId    String
  content      String?

  // ── File submission (student uploads when submitting) ──
  fileUrl  String?   // Supabase Storage public URL
  fileName String?   // original filename e.g. "my_recitation.mp3"
  fileType String?   // MIME type e.g. "audio/mpeg", "image/png"
  filePath String?   // ← ADD THIS (Supabase Storage path, for deletion)
  
  grade        String?
  feedback     String?
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student       @relation(fields: [studentId], references: [id])
}

// ─────────────────────────────────────────────────────────
// PROGRESS REPORT — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model ProgressReport {
  id           String       @id @default(cuid())
  teacherId    String
  studentId    String
  enrollmentId String?
  period       String // e.g. "Week 12", "Month 3", "June 2026"
  courseType   CourseType
  status       ReportStatus @default(DRAFT)

  // Structured report fields
  overallRating   Int? // 1–5
  tajweedProgress String?
  recitationNotes String?
  behaviourNotes  String?
  homeworkNotes   String?
  teacherMessage  String? // personal message to parent
  nextSteps       String?

  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  attachmentPath String?   // Supabase Storage path, for deletion

  updatedSinceSent Boolean   @default(false)  // edited after being SENT
  lastSentAt       DateTime?                  // most recent (re)send time

  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  teacher    Teacher     @relation("TeacherReports", fields: [teacherId], references: [id])
  student    Student        @relation("StudentReports", fields: [studentId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])

  @@index([teacherId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────
// ATTENDANCE RECORD — MODULE 2 (NEW)
// ─────────────────────────────────────────────────────────

model AttendanceRecord {
  id           String           @id @default(cuid())
  teacherId    String
  studentId    String
  sessionId    String           @unique // one record per session
  enrollmentId String?
  status       AttendanceStatus
  notes        String?
  markedAt     DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  teacher    Teacher      @relation("TeacherAttendanceRecords", fields: [teacherId], references: [id])
  student    Student         @relation("StudentAttendance", fields: [studentId], references: [id])
  session    ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment Enrollment?  @relation(fields: [enrollmentId], references: [id])

  @@index([teacherId])
  @@index([studentId])
  @@index([sessionId])
}

// ─────────────────────────────────────────────────────────
// ENROLLMENT REQUEST — MODULE 3
// ─────────────────────────────────────────────────────────
model EnrollmentRequest {
  id               String                  @id @default(cuid())
  studentId        String
  courseType       CourseInterest
  genderPreference String?
  preferredDays    String[]
  preferredTime    String?
  message          String?
  status           EnrollmentRequestStatus @default(PENDING)
  adminNotes       String?
  rejectionReason  String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("enrollment_requests")
}

// ─── COMMUNICATION LOG ─────────────────────────────────────
// One row per send attempt (success OR failure). The stored {to, subject,
// html, from} is the exact rendered email — enough to retry as-is or edit
// and resend. Failure is a first-class status, not an edge case.
model CommunicationLog {
  id            String        @id @default(cuid())
  channel       CommChannel   @default(EMAIL)   // EMAIL now; WHATSAPP-ready
  type          CommType
  status        CommStatus                       // SENT | FAILED
  toAddress     String                           // recipient(s), joined for display/search
  subject       String?
  fromAddress   String?
  providerId    String?                          // Resend data.id (or WA message id)
  failureReason String?                          // captured error message
  failureCode   String?                          // error name/code if present
  html          String?                          // rendered body — needed to retry/resend-edit
  relatedType   String?                          // "Lead" | "Student" | "Enrollment" | "ProgressReport" | "Teacher"
  relatedId     String?
  resendOfId    String?                          // if this row is a resend of another
  resendOf      CommunicationLog?  @relation("Resends", fields: [resendOfId], references: [id])
  resends       CommunicationLog[] @relation("Resends")
  resolvedAt    DateTime?                        // set when a failure is resolved (successful resend or manual dismiss)
  createdAt     DateTime      @default(now())

  @@index([status])
  @@index([type])
  @@index([toAddress])
  @@index([createdAt])
  @@index([resendOfId])
  @@map("communication_logs")
}